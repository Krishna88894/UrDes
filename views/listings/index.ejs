<% layout('layouts/boilerplate') %>
<div id="listings">
    <h2 class="section-title">Available Listings</h2>
    <p class="section-subtitle">Hand-picked stays with the details you need at a glance.</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 listing-grid">
        <% list.forEach(listing => { %>
            <div class="col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card">
                        <img src="<%= (listing.image && (listing.image.url || listing.image)) ? (listing.image.url || listing.image) : 'https://www.elegantthemes.com/blog/wp-content/uploads/2020/08/000-http-error-codes.png' %>" class="card-img-top" alt="<%= listing.title %>">
                        <div class="card-body">
                            <h5 class="card-title"><%= listing.title %></h5>
                            <p class="card-price"><strong>Price:</strong> $<%= listing.price %>/night</p>
                        </div>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</div>
