<% layout("layouts/boilerplate") %>
<div class="form-panel">
    <h2 class="page-title">Log in to your UrDes account</h2>
    <form action="/login" method="POST" class="needs-validation" novalidate>
        <div>
            <label class="form-label" for="login-username">Username</label>
            <input
                id="login-username"
                type="text"
                name="username"
                class="form-control"
                minlength="3"
                maxlength="30"
                required
            >
            <div class="invalid-feedback">Please enter a valid username (3-30 characters).</div>
        </div>
        <div>
            <label class="form-label" for="login-password">Enter your password</label>
            <input
                id="login-password"
                type="password"
                name="password"
                class="form-control"
                minlength="6"
                required
            >
            <div class="invalid-feedback">Enter valid password.</div>
        </div>
        <button type="submit" class="btn btn-brand btn-lg">Log In</button>
    </form>
</div>
